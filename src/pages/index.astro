---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteConfig.title,
  url: siteConfig.url,
  description: siteConfig.description,
  author: {
    "@type": "Person",
    name: siteConfig.author,
  },
};
---

<BaseLayout title={siteConfig.title} description={siteConfig.description} jsonLd={jsonLd}>
  <section class="hero">
    <div class="hero-copy">
      <p class="hero-kicker">Independent developer / AI / Web / Data products</p>
      <h1>Spring builds small useful things.</h1>
      <p class="lead">
        A quiet personal lab for shipping web tools, writing practical notes, and turning fuzzy product ideas into things people can actually visit.
      </p>
      <div class="actions">
        <a class="button" href="/blog/">Read the blog</a>
        <a class="button-secondary" href="/projects/">View projects</a>
      </div>
    </div>
    <aside class="panel proof-panel" aria-label="Featured project">
      <p class="eyebrow">Live build</p>
      <h2>World Cup Live</h2>
      <p>
        A multilingual football data site for live scores, schedules, teams, predictions, SEO experiments, and Cloudflare deployment notes.
      </p>
      <a href={siteConfig.projectLinks.worldCup} target="_blank" rel="noopener">Open worldcup.imspring.cn</a>
    </aside>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <p class="eyebrow">Latest dispatches</p>
        <h2>Recent writing</h2>
      </div>
      <a class="text-link" href="/blog/">All essays</a>
    </div>
    <div class="post-list">
      {posts.map((post, index) => (
        <article class="post-card" data-index={String(index + 1).padStart(2, "0")}>
          <h3><a href={`/blog/${post.id}/`}>{post.data.title}</a></h3>
          <p>{post.data.description}</p>
          <div class="meta">
            <time datetime={post.data.date.toISOString()}>{post.data.date.toLocaleDateString("zh-CN")}</time>
            {post.data.tags.slice(0, 3).map((tag) => <span class="tag">{tag}</span>)}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section manifesto-grid" aria-label="Site principles">
    <div class="project-card">
      <p class="eyebrow">01 / Method</p>
      <h3>Ship, then write clearly.</h3>
      <p>Every note keeps the real tradeoffs visible: constraints, choices, small failures, and what changed after shipping.</p>
      <a href="/about/">About this site</a>
    </div>
    <div class="project-card">
      <p class="eyebrow">02 / Stack</p>
      <h3>Small tools over heavy platforms.</h3>
      <p>Focused on Astro, Next.js, Cloudflare, AI-assisted development, and data products that can be maintained calmly.</p>
      <a href="/blog/">Browse writing</a>
    </div>
    <div class="project-card">
      <p class="eyebrow">03 / Contact</p>
      <h3>Useful conversations welcome.</h3>
      <p>If you are building tools, content sites, or practical AI products, the contact page is the simplest place to start.</p>
      <a href="/contact/">Contact Spring</a>
    </div>
  </section>
</BaseLayout>
