---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteConfig.title,
  url: siteConfig.url,
  description: siteConfig.description,
  author: {
    "@type": "Person",
    name: siteConfig.author,
  },
};
---

<BaseLayout title={siteConfig.title} description={siteConfig.description} jsonLd={jsonLd}>
  <section class="hero">
    <div class="hero-copy">
      <p class="hero-kicker">独立开发 / AI / Web / 数据应用</p>
      <h1>imspring</h1>
      <p class="lead">
        我在这里记录项目、技术实践和产品想法。内容围绕 AI、Web 工具、数据应用和独立开发。
      </p>
      <div class="actions">
        <a class="button" href="/blog/">阅读博客</a>
        <a class="button-secondary" href="/projects/">查看项目</a>
      </div>
    </div>
    <aside class="panel proof-panel" aria-label="项目入口">
      <p class="eyebrow">项目入口</p>
      <h2>TestData</h2>
      <p>测试数据与接口调试相关站点，整理常用样例、数据和工具入口。</p>
      <a href={siteConfig.projectLinks.testData} target="_blank" rel="noopener">访问 testdata.imspring.cn</a>
      <div class="project-mini">
        <span>World Cup Live</span>
        <a href={siteConfig.projectLinks.worldCup} target="_blank" rel="noopener">worldcup.imspring.cn</a>
      </div>
    </aside>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <p class="eyebrow">最新更新</p>
        <h2>最新文章</h2>
      </div>
      <a class="text-link" href="/blog/">全部文章</a>
    </div>
    <div class="post-list">
      {posts.map((post, index) => (
        <article class="post-card" data-index={String(index + 1).padStart(2, "0")}>
          <h3><a href={`/blog/${post.id}/`}>{post.data.title}</a></h3>
          <p>{post.data.description}</p>
          <div class="meta">
            <time datetime={post.data.date.toISOString()}>{post.data.date.toLocaleDateString("zh-CN")}</time>
            {post.data.tags.slice(0, 3).map((tag) => <span class="tag">{tag}</span>)}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section manifesto-grid" aria-label="站点内容">
    <div class="project-card">
      <p class="eyebrow">01 / 项目</p>
      <h3>先做出来</h3>
      <p>记录真实项目的需求、取舍、部署和后续优化。</p>
      <a href="/projects/">看项目</a>
    </div>
    <div class="project-card">
      <p class="eyebrow">02 / 文章</p>
      <h3>少写空话</h3>
      <p>文章以实践笔记为主，尽量给出背景、过程和结果。</p>
      <a href="/blog/">看文章</a>
    </div>
    <div class="project-card">
      <p class="eyebrow">03 / 交流</p>
      <h3>欢迎联系</h3>
      <p>如果你也在做工具、内容站或 AI 产品，可以从联系页开始。</p>
      <a href="/contact/">联系 Spring</a>
    </div>
  </section>
</BaseLayout>
