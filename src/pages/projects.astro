---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";
---

<BaseLayout title="项目" description="Spring 的项目列表：TestData、World Cup Live 等。">
  <section class="page">
    <h1>项目</h1>
    <p class="page-description">正在维护的站点和工具。</p>
  </section>

  <section class="section project-list">
    <article class="project-card">
      <p class="eyebrow">新站点</p>
      <h2>TestData</h2>
      <p>测试数据与接口调试相关站点，用于整理常用测试数据、样例和工具入口。</p>
      <a href={siteConfig.projectLinks.testData} target="_blank" rel="noopener">访问 testdata.imspring.cn</a>
    </article>

    <article class="project-card">
      <p class="eyebrow">数据项目</p>
      <h2>World Cup Live</h2>
      <p>世界杯赛程、比分、球队和数据展示项目，也用于记录内容站的 SEO 与部署实践。</p>
      <a href={siteConfig.projectLinks.worldCup} target="_blank" rel="noopener">访问 worldcup.imspring.cn</a>
    </article>
  </section>
</BaseLayout>
